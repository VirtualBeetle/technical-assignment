# Plain runtime env var read by next.config.js's rewrites() - NOT a
# NEXT_PUBLIC_ var, so it does not need to be known at Docker build time.
# Local docker-compose: http://backend:8000 (the sibling service's Docker DNS name)
# Render / separately-hosted backend: the backend service's own https:// URL
BACKEND_INTERNAL_URL=http://localhost:8000
